---
const rawBASE = (import.meta as any).env?.BASE_URL ?? '/';
const BASE = rawBASE.endsWith('/') ? rawBASE : `${rawBASE}/`;
---
<style>
  .logo-container {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .logo-link {
    display: block;
  }

  img {
    display: block;
    height: 50px;
    width: auto;
  }

  @media screen and (max-width: 520px) {
    img {
      display: none;
    }
  }
</style>

<div class="logo-container">
  <a class="logo-link" href="https://www.uam.es/ciencias/facultad/departamentos/fisica-teorica" target="_blank" rel="noopener noreferrer">
    <img alt="DFT Logo" src={`${BASE}assets/DFT.png`} />
  </a>
  <a class="logo-link" href="https://www.ciaff.uam.es/" target="_blank" rel="noopener noreferrer">
    <img alt="CIAFF Logo" src={`${BASE}assets/ciaff.jpg`} />
  </a>
  <a class="logo-link" href="https://www.ift.uam-csic.es/en/" target="_blank" rel="noopener noreferrer">
    <img alt="IFT Logo" src={`${BASE}assets/ift.png`} />
  </a>
</div>
