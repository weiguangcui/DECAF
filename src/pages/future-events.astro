---
import BaseLayout from '../layouts/BaseLayout.astro';
import * as fs from 'node:fs';
import * as path from 'node:path';
import matter from 'gray-matter';
import { marked } from 'marked';

const filePath = path.resolve(process.cwd(), 'public/assets/future-events.md');
let frontmatter: any = {};
let content = '';

if (fs.existsSync(filePath)) {
  const fileContent = fs.readFileSync(filePath, 'utf-8');
  const parsed = matter(fileContent);
  frontmatter = parsed.data;
  content = parsed.content;
} else {
  content = '# Future Events\n\nNo future events found. Please create `public/assets/future-events.md`.';
}

const htmlContent = marked.parse(content);
const permalink = `${Astro.site?.href || ''}future-events`;
---

<BaseLayout 
  title={frontmatter.title || 'Future Events'} 
  description={frontmatter.description || 'Upcoming DeCAF Seminars'} 
  permalink={permalink} 
  current="future"
>
  <div class="events-page-wrapper content">
    <div class="event-markdown" set:html={htmlContent} />
  </div>
</BaseLayout>

<style>
  .events-page-wrapper {
    width: 100%;
  }

  .event-markdown {
    margin-top: 2rem;
  }
  
  :global(.event-markdown table) {
    width: 100%;
    margin-top: 2rem;
    table-layout: fixed; /* This makes the column widths stick strictly to what we set */
  }
  
  :global(.event-markdown th) {
    text-align: left;
  }

  /* Control Column Widths (total should be ~100%) */
  
  /* Column 1: Date */
  :global(.event-markdown th:nth-child(1)),
  :global(.event-markdown td:nth-child(1)) {
    width: 10%;
  }

  /* Column 2: Time */
  :global(.event-markdown th:nth-child(2)),
  :global(.event-markdown td:nth-child(2)) {
    width: 6%;
  }

  /* Column 3: Speaker */
  :global(.event-markdown th:nth-child(3)),
  :global(.event-markdown td:nth-child(3)) {
    width: 15%;
  }

  /* Column 4: Affiliation */
  :global(.event-markdown th:nth-child(4)),
  :global(.event-markdown td:nth-child(4)) {
    width: 15%;
  }

  /* Column 5: Topic / Title */
  :global(.event-markdown th:nth-child(5)),
  :global(.event-markdown td:nth-child(5)) {
    width: 42%;
  }

  /* Column 6: Location */
  :global(.event-markdown th:nth-child(6)),
  :global(.event-markdown td:nth-child(6)) {
    width: 12%;
  }
</style>
