---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllEvents } from '../../lib/events';
import '../../styles/home.css';

export async function getStaticPaths() {
  const events = await getAllEvents();
  return events.map((ev) => ({
    params: { id: ev.dir },
    props: { event: ev },
  }));
}

const { event } = Astro.props;
const BASE: string = (import.meta as any).env?.BASE_URL || '/';

function escapeHtml(str: string): string {
  return str
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#039;');
}

function simpleMarkdownToHtml(md: string): string {
  // Very small converter: supports #/## headings and paragraphs.
  const lines = md.replace(/\r/g, '').split('\n');
  const out: string[] = [];
  let para: string[] = [];

  function flushPara() {
    if (para.length) {
      const text = escapeHtml(para.join(' ')).trim();
      if (text) out.push(`<p>${text}</p>`);
      para = [];
    }
  }

  for (const raw of lines) {
    const line = raw.trimEnd();
    if (!line.trim()) { flushPara(); continue; }
    if (line.startsWith('## ')) { flushPara(); out.push(`<h2>${escapeHtml(line.slice(3))}</h2>`); continue; }
    if (line.startsWith('# ')) { flushPara(); out.push(`<h1>${escapeHtml(line.slice(2))}</h1>`); continue; }
    para.push(line);
  }
  flushPara();
  return out.join('\n');
}

const mdHtml = event.content ? simpleMarkdownToHtml(event.content) : null;
const title = event.title || 'Event';
const description = event.excerpt || 'DeCAF Event';
const permalink = `${Astro.site?.href || ''}blog/${event.dir}`;
---

<BaseLayout title={title} description={description} permalink={permalink} current="blog">
  <div class="home-container">
    <div class="home-copy">
      <a href={`${BASE}blog`} class="back-link">&larr; Back to Events</a>
      {event.title && (
        <div class="event-title">{event.title}</div>
      )}
      {(event.speaker || event.affiliation) && (
        <p class="event-meta-primary">
          {event.speaker ? (<span class="event-speaker">{event.speaker}</span>) : ''}
          {event.affiliation ? ` (${event.affiliation})` : ''}
        </p>
      )}
      {(event.date || event.time || event.location || (!event.title && !event.speaker && event.excerpt)) && (
        <p class="event-meta-secondary">
          {event.date ? `${event.date}` : ''}
          {event.time ? ` • ${event.time}` : ''}
          {event.location ? ` • ${event.location}` : ''}
          {(!event.title && !event.speaker && event.excerpt) ? ` • ${event.excerpt}` : ''}
        </p>
      )}

      {mdHtml && (
        <div class="event-markdown" set:html={mdHtml} />
      )}
    </div>

    <div class="hero-image-container">
      {event.imagePath ? (
        <picture>
          <img
            class="hero-image"
            alt={event.title ? `${event.title} poster` : 'Event image'}
            src={event.imagePath.startsWith('/') ? `${BASE}${event.imagePath.slice(1)}` : `${BASE}${event.imagePath}`}
            width="550"
            height="466"
          />
        </picture>
      ) : (
        <picture>
          <img class="hero-image" alt="Illustration of person reading a book" src={`${BASE}assets/home-illustration-small.webp`} width="550" height="466" />
        </picture>
      )}
    </div>
  </div>
</BaseLayout>

<style>
  .back-link {
    display: inline-block;
    margin-bottom: 2rem;
    color: var(--color-text);
    text-decoration: none;
    opacity: 0.8;
  }
  .back-link:hover {
    opacity: 1;
    text-decoration: underline;
  }
</style>
